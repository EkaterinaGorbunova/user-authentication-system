<div class="row justify-content-center align-items-center" style="min-height: 90vh;">
  <div class="col-12 col-sm-10 col-md-7 col-lg-5 col-xl-4">

    <!-- Logo -->
    <div class="text-center mb-4">
      <a href="/">
        <img src="/public/secure-icon.png" alt="icon" width="52" class="mb-3" style="filter: drop-shadow(0 0 12px rgba(0,212,255,0.6));" />
      </a>
      <h1 class="fs-3 fw-bold gradient-text mb-1">Welcome back</h1>
      <p style="color: var(--text-muted); font-size: 0.9rem;">Sign in to your account</p>
    </div>

    <div class="glass-card p-4 p-md-5">

      <% if (messages.error) { %>
        <div class="alert-neon-danger mb-4">
          <i class="fa-solid fa-circle-exclamation me-2"></i><%= messages.error %>
        </div>
      <% } %>

      <!-- Local login form -->
      <form action="/auth/login" method="POST">
        <div class="mb-3">
          <label class="form-label-neon" for="email">Email</label>
          <div class="position-relative">
            <i class="fa-solid fa-envelope position-absolute" style="left:14px; top:50%; transform:translateY(-50%); color:var(--text-muted-custom); font-size:0.85rem;"></i>
            <input
              type="email"
              id="email"
              name="email"
              class="form-control-neon w-100"
              placeholder="you@example.com"
              style="padding-left: 38px;"
              required
            />
          </div>
        </div>

        <div class="mb-4">
          <label class="form-label-neon" for="password">Password</label>
          <div class="position-relative">
            <i class="fa-solid fa-lock position-absolute" style="left:14px; top:50%; transform:translateY(-50%); color:var(--text-muted-custom); font-size:0.85rem;"></i>
            <input
              type="password"
              id="password"
              name="password"
              class="form-control-neon w-100"
              placeholder="••••••••"
              style="padding-left: 38px;"
              required
            />
          </div>
        </div>

        <button type="submit" class="btn-neon w-100 d-flex align-items-center justify-content-center gap-2">
          <span><i class="fa-solid fa-right-to-bracket"></i> Sign In</span>
        </button>
      </form>

      <div class="divider-neon"></div>

      <!-- GitHub OAuth -->
      <a href="/auth/github" class="btn-github w-100 d-flex align-items-center justify-content-center gap-2 text-decoration-none">
        <i class="fa-brands fa-github fs-5"></i>
        <span>Continue with GitHub</span>
      </a>

    </div>

    <!-- Demo credentials hint -->
    <div class="glass-card mt-3 p-3">
      <p class="mb-2" style="color: var(--text-muted); font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">
        <i class="fa-solid fa-flask-vial me-1" style="color: var(--indigo);"></i> Demo accounts
      </p>
      <div class="d-flex flex-column gap-2" style="font-size: 0.82rem;">
        <div class="d-flex align-items-center gap-2">
          <span class="badge-neon" style="flex-shrink:0;">user</span>
          <span class="copy-text" data-copy="jimmy123@gmail.com">jimmy123@gmail.com</span>
          <span style="color: #94a3b8;">/</span>
          <span class="copy-text" style="font-family:monospace;" data-copy="jimmy123!">jimmy123!</span>
        </div>
        <div class="d-flex align-items-center gap-2">
          <span class="badge-neon-purple" style="flex-shrink:0;">admin</span>
          <span class="copy-text" data-copy="jonathan123@gmail.com">jonathan123@gmail.com</span>
          <span style="color: #94a3b8;">/</span>
          <span class="copy-text" style="font-family:monospace;" data-copy="jonathan123!">jonathan123!</span>
        </div>
      </div>
    </div>

  </div>
</div>

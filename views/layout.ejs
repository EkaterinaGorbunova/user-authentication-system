<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="shortcut icon" type="image/x-icon" href="/public/secure-icon.png" />
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>NodeJS Auth App</title>
    <style>
      :root {
        --indigo: #4f46e5;
        --indigo-hover: #4338ca;
        --indigo-light: #6366f1;
        --green: #16a34a;
        --bg: #f8fafc;
        --bg-card: #ffffff;
        --border: #e2e8f0;
        --border-focus: #4f46e5;
        --text: #0f172a;
        --text-muted: #64748b;
        --text-subtle: #94a3b8;
      }

      * { box-sizing: border-box; }

      body {
        font-family: 'Space Grotesk', sans-serif;
        background-color: var(--bg);
        min-height: 100vh;
        color: var(--text);
      }

      /* Card */
      .glass-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 14px;
        box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06), 0 4px 16px rgba(15, 23, 42, 0.04);
        transition: box-shadow 0.2s, border-color 0.2s;
      }

      .glass-card:hover {
        box-shadow: 0 2px 8px rgba(15, 23, 42, 0.08), 0 8px 24px rgba(15, 23, 42, 0.06);
        border-color: #cbd5e1;
      }

      /* Gradient text */
      .gradient-text {
        background: linear-gradient(135deg, var(--indigo) 0%, var(--indigo-light) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* Buttons */
      .btn-neon {
        background: var(--indigo);
        border: none;
        color: #fff;
        font-weight: 600;
        letter-spacing: 0.2px;
        border-radius: 9px;
        padding: 10px 24px;
        transition: background 0.15s, box-shadow 0.15s, transform 0.15s;
      }

      .btn-neon:hover {
        background: var(--indigo-hover);
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(79, 70, 229, 0.3);
      }

      .btn-neon span {
        position: relative;
        z-index: 1;
      }

      .btn-glass {
        background: #fff;
        border: 1px solid var(--border);
        color: #334155;
        font-weight: 500;
        border-radius: 9px;
        padding: 10px 24px;
        transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
      }

      .btn-glass:hover {
        border-color: #94a3b8;
        background: #f8fafc;
        color: #0f172a;
        box-shadow: 0 1px 4px rgba(15, 23, 42, 0.06);
      }

      .btn-github {
        background: #fff;
        border: 1px solid var(--border);
        color: #334155;
        font-weight: 500;
        border-radius: 9px;
        padding: 10px 24px;
        transition: border-color 0.15s, background 0.15s;
      }

      .btn-github:hover {
        background: #f1f5f9;
        border-color: #94a3b8;
        color: #0f172a;
      }

      .btn-danger-glass {
        background: #fff5f5;
        border: 1px solid #fecaca;
        color: #dc2626;
        font-weight: 500;
        border-radius: 8px;
        padding: 6px 16px;
        font-size: 0.85rem;
        transition: background 0.15s, border-color 0.15s;
      }

      .btn-danger-glass:hover {
        background: #fee2e2;
        border-color: #f87171;
        color: #b91c1c;
      }

      /* Form inputs */
      .form-control-neon {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 9px;
        color: var(--text);
        padding: 11px 16px;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.95rem;
        transition: border-color 0.15s, box-shadow 0.15s;
      }

      .form-control-neon::placeholder { color: var(--text-subtle); }

      .form-control-neon:focus {
        border-color: var(--border-focus);
        box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
        outline: none;
        color: var(--text);
      }

      .form-label-neon {
        color: #374151;
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.3px;
        margin-bottom: 6px;
      }

      /* Alert */
      .alert-neon-danger {
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 9px;
        color: #dc2626;
        padding: 12px 16px;
        font-size: 0.9rem;
      }

      /* Badge / pill */
      .badge-neon {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #3b82f6;
        border-radius: 20px;
        padding: 3px 11px;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.4px;
        text-transform: uppercase;
      }

      .badge-neon-purple {
        background: #f5f3ff;
        border: 1px solid #ddd6fe;
        color: var(--indigo);
        border-radius: 20px;
        padding: 3px 11px;
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.4px;
      }

      /* Divider */
      .divider-neon {
        border: none;
        height: 1px;
        background: var(--border);
        margin: 24px 0;
      }

      /* Glow dot */
      .glow-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #22c55e;
        display: inline-block;
      }

      /* Feature icon */
      .feature-icon {
        width: 44px;
        height: 44px;
        border-radius: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
      }

      .feature-icon-cyan {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #3b82f6;
      }

      .feature-icon-purple {
        background: #f5f3ff;
        border: 1px solid #ddd6fe;
        color: var(--indigo);
      }

      .feature-icon-pink {
        background: #fdf4ff;
        border: 1px solid #f0abfc;
        color: #a855f7;
      }

      .feature-icon-green {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #16a34a;
      }

      /* Scrollbar */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: var(--bg); }
      ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

      /* Link */
      a.neon-link {
        color: var(--indigo);
        text-decoration: none;
        transition: color 0.15s;
      }

      a.neon-link:hover { color: var(--indigo-hover); }

      /* Navbar-like top bar feel */
      .page-header {
        border-bottom: 1px solid var(--border);
        background: rgba(255,255,255,0.8);
        backdrop-filter: blur(8px);
        margin: -1rem -12px 1.5rem;
        padding: 0.75rem 12px;
      }

      /* Copy on click */
      .copy-text {
        cursor: pointer;
        color: var(--text-muted);
        border-radius: 4px;
        padding: 1px 4px;
        transition: background 0.15s, color 0.15s;
        position: relative;
        display: inline-block;
      }
      .copy-text:hover { background: #eff6ff; color: var(--indigo); }

      .copy-text::after {
        content: 'Copy';
        position: absolute;
        bottom: calc(100% + 5px);
        left: 50%;
        transform: translateX(-50%);
        background: #1e293b;
        color: #fff;
        font-size: 0.68rem;
        font-weight: 500;
        font-family: 'Space Grotesk', sans-serif;
        padding: 3px 8px;
        border-radius: 5px;
        white-space: nowrap;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.15s;
        z-index: 10;
      }
      .copy-text:hover::after { opacity: 1; }

      .copy-toast {
        position: fixed;
        background: #1e293b;
        color: #fff;
        font-size: 0.68rem;
        font-weight: 500;
        font-family: 'Space Grotesk', sans-serif;
        padding: 3px 8px;
        border-radius: 5px;
        white-space: nowrap;
        pointer-events: none;
        z-index: 9999;
        transition: opacity 0.3s;
      }
    </style>
  </head>

  <body>
    <div class="container py-4"><%- body %></div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/public/copy.js"></script>
  </body>
</html>

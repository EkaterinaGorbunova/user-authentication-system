<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="shortcut icon" type="image/x-icon" href="/public/secure-icon.png" />
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>NodeJS Auth App</title>
    <style>
      :root {
        --neon-cyan: #00d4ff;
        --neon-purple: #7b2fff;
        --neon-pink: #ff00aa;
        --neon-green: #00ff88;
        --bg-dark: #07071a;
        --bg-card: rgba(255, 255, 255, 0.04);
        --bg-card-hover: rgba(255, 255, 255, 0.07);
        --border-glow: rgba(0, 212, 255, 0.25);
        --text-muted-custom: #8892b0;
      }

      * {
        box-sizing: border-box;
      }

      body {
        font-family: 'Space Grotesk', sans-serif;
        background-color: var(--bg-dark);
        background-image:
          radial-gradient(ellipse at 20% 50%, rgba(123, 47, 255, 0.08) 0%, transparent 50%),
          radial-gradient(ellipse at 80% 20%, rgba(0, 212, 255, 0.08) 0%, transparent 50%);
        min-height: 100vh;
        color: #cdd6f4;
      }

      /* Glassmorphism card */
      .glass-card {
        background: var(--bg-card);
        border: 1px solid var(--border-glow);
        border-radius: 16px;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow:
          0 0 0 1px rgba(0, 212, 255, 0.05),
          0 20px 40px rgba(0, 0, 0, 0.4),
          inset 0 1px 0 rgba(255, 255, 255, 0.06);
        transition: border-color 0.3s, box-shadow 0.3s;
      }

      .glass-card:hover {
        border-color: rgba(0, 212, 255, 0.4);
        box-shadow:
          0 0 20px rgba(0, 212, 255, 0.08),
          0 20px 40px rgba(0, 0, 0, 0.5),
          inset 0 1px 0 rgba(255, 255, 255, 0.08);
      }

      /* Neon text */
      .neon-text {
        color: var(--neon-cyan);
        text-shadow: 0 0 20px rgba(0, 212, 255, 0.5), 0 0 40px rgba(0, 212, 255, 0.2);
      }

      .neon-text-purple {
        color: var(--neon-purple);
        text-shadow: 0 0 20px rgba(123, 47, 255, 0.5);
      }

      /* Gradient text */
      .gradient-text {
        background: linear-gradient(135deg, var(--neon-cyan) 0%, var(--neon-purple) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* Buttons */
      .btn-neon {
        background: linear-gradient(135deg, var(--neon-cyan), var(--neon-purple));
        border: none;
        color: #fff;
        font-weight: 600;
        letter-spacing: 0.5px;
        border-radius: 10px;
        padding: 10px 24px;
        position: relative;
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
      }

      .btn-neon::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, var(--neon-purple), var(--neon-cyan));
        opacity: 0;
        transition: opacity 0.3s;
      }

      .btn-neon:hover {
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0, 212, 255, 0.35), 0 4px 15px rgba(123, 47, 255, 0.3);
      }

      .btn-neon:hover::before {
        opacity: 1;
      }

      .btn-neon span {
        position: relative;
        z-index: 1;
      }

      .btn-glass {
        background: var(--bg-card);
        border: 1px solid var(--border-glow);
        color: #cdd6f4;
        font-weight: 500;
        border-radius: 10px;
        padding: 10px 24px;
        backdrop-filter: blur(8px);
        transition: border-color 0.2s, background 0.2s, transform 0.2s, box-shadow 0.2s;
      }

      .btn-glass:hover {
        background: var(--bg-card-hover);
        border-color: var(--neon-cyan);
        color: var(--neon-cyan);
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(0, 212, 255, 0.15);
      }

      .btn-github {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: #cdd6f4;
        font-weight: 500;
        border-radius: 10px;
        padding: 10px 24px;
        transition: border-color 0.2s, background 0.2s, transform 0.2s;
      }

      .btn-github:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.3);
        color: #fff;
        transform: translateY(-2px);
      }

      .btn-danger-glass {
        background: rgba(255, 0, 85, 0.08);
        border: 1px solid rgba(255, 0, 85, 0.3);
        color: #ff4d6d;
        font-weight: 500;
        border-radius: 10px;
        padding: 6px 16px;
        font-size: 0.85rem;
        transition: background 0.2s, border-color 0.2s, transform 0.2s;
      }

      .btn-danger-glass:hover {
        background: rgba(255, 0, 85, 0.18);
        border-color: #ff4d6d;
        color: #ff4d6d;
        transform: translateY(-1px);
      }

      /* Form inputs */
      .form-control-neon {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(0, 212, 255, 0.2);
        border-radius: 10px;
        color: #cdd6f4;
        padding: 12px 16px;
        font-family: 'Space Grotesk', sans-serif;
        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
      }

      .form-control-neon::placeholder {
        color: #4a5568;
      }

      .form-control-neon:focus {
        background: rgba(0, 212, 255, 0.04);
        border-color: var(--neon-cyan);
        box-shadow: 0 0 0 3px rgba(0, 212, 255, 0.12);
        color: #e2e8f0;
        outline: none;
      }

      .form-label-neon {
        color: var(--text-muted-custom);
        font-size: 0.85rem;
        font-weight: 500;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin-bottom: 8px;
      }

      /* Alert */
      .alert-neon-danger {
        background: rgba(255, 0, 85, 0.1);
        border: 1px solid rgba(255, 77, 109, 0.4);
        border-radius: 10px;
        color: #ff4d6d;
        padding: 12px 16px;
        font-size: 0.9rem;
      }

      /* Badge / pill */
      .badge-neon {
        background: linear-gradient(135deg, rgba(0, 212, 255, 0.15), rgba(123, 47, 255, 0.15));
        border: 1px solid rgba(0, 212, 255, 0.3);
        color: var(--neon-cyan);
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.5px;
      }

      .badge-neon-purple {
        background: linear-gradient(135deg, rgba(123, 47, 255, 0.15), rgba(255, 0, 170, 0.1));
        border: 1px solid rgba(123, 47, 255, 0.4);
        color: #b48aff;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 0.75rem;
        font-weight: 600;
      }

      /* Divider */
      .divider-neon {
        border: none;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(0, 212, 255, 0.3), transparent);
        margin: 24px 0;
      }

      /* Glow dot */
      .glow-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--neon-green);
        box-shadow: 0 0 8px var(--neon-green), 0 0 16px rgba(0, 255, 136, 0.4);
        display: inline-block;
      }

      /* Feature icon */
      .feature-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
      }

      .feature-icon-cyan {
        background: rgba(0, 212, 255, 0.1);
        border: 1px solid rgba(0, 212, 255, 0.25);
        color: var(--neon-cyan);
      }

      .feature-icon-purple {
        background: rgba(123, 47, 255, 0.1);
        border: 1px solid rgba(123, 47, 255, 0.25);
        color: #b48aff;
      }

      .feature-icon-pink {
        background: rgba(255, 0, 170, 0.1);
        border: 1px solid rgba(255, 0, 170, 0.25);
        color: #ff66cc;
      }

      .feature-icon-green {
        background: rgba(0, 255, 136, 0.1);
        border: 1px solid rgba(0, 255, 136, 0.25);
        color: var(--neon-green);
      }

      /* Scrollbar */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: var(--bg-dark); }
      ::-webkit-scrollbar-thumb { background: rgba(0, 212, 255, 0.2); border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: rgba(0, 212, 255, 0.4); }

      /* Link */
      a.neon-link {
        color: var(--neon-cyan);
        text-decoration: none;
        transition: text-shadow 0.2s, color 0.2s;
      }

      a.neon-link:hover {
        color: #fff;
        text-shadow: 0 0 10px rgba(0, 212, 255, 0.6);
      }
    </style>
  </head>

  <body>
    <div class="container py-4"><%- body %></div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>

<!-- Header -->
<div class="d-flex align-items-center justify-content-between mb-4 pt-2">
  <div>
    <div class="d-flex align-items-center gap-2 mb-1">
      <h1 class="fs-4 fw-bold gradient-text mb-0">Admin Dashboard</h1>
      <span class="badge-neon-purple"><i class="fa-solid fa-crown me-1"></i>Admin</span>
    </div>
    <p style="color: var(--text-muted-custom); font-size: 0.9rem; margin: 0;">
      <span class="glow-dot me-2"></span> Logged in as <%= user.name %>
    </p>
  </div>
  <div class="d-flex gap-2">
    <a href="/dashboard" class="btn-glass d-inline-flex align-items-center gap-2 text-decoration-none">
      <i class="fa-solid fa-gauge-high" style="font-size: 0.85rem;"></i> Dashboard
    </a>
    <a href="/" class="btn-glass d-inline-flex align-items-center gap-2 text-decoration-none">
      <i class="fa-solid fa-house" style="font-size: 0.85rem;"></i> Home
    </a>
    <a href="/auth/logout" class="btn-glass d-inline-flex align-items-center gap-2 text-decoration-none" style="color: #dc2626; border-color: #fecaca;">
      <i class="fa-solid fa-right-from-bracket" style="font-size: 0.85rem;"></i> Logout
    </a>
  </div>
</div>

<!-- Capabilities -->
<div class="row g-3 mb-4">
  <div class="col-sm-4">
    <div class="glass-card p-3 d-flex align-items-center gap-3">
      <div class="feature-icon feature-icon-cyan" style="flex-shrink:0;">
        <i class="fa-solid fa-eye"></i>
      </div>
      <div>
        <div class="fw-semibold" style="color:#0f172a; font-size:0.9rem;">View Sessions</div>
        <div style="color:var(--text-muted); font-size:0.78rem;">Monitor all active users</div>
      </div>
    </div>
  </div>
  <div class="col-sm-4">
    <div class="glass-card p-3 d-flex align-items-center gap-3">
      <div class="feature-icon feature-icon-pink" style="flex-shrink:0;">
        <i class="fa-solid fa-ban"></i>
      </div>
      <div>
        <div class="fw-semibold" style="color:#0f172a; font-size:0.9rem;">Terminate Sessions</div>
        <div style="color:var(--text-muted); font-size:0.78rem;">Force logout any user</div>
      </div>
    </div>
  </div>
  <div class="col-sm-4">
    <div class="glass-card p-3 d-flex align-items-center gap-3">
      <div class="feature-icon feature-icon-purple" style="flex-shrink:0;">
        <i class="fa-solid fa-chart-bar"></i>
      </div>
      <div>
        <div class="fw-semibold" style="color:#0f172a; font-size:0.9rem;">Activity Logs</div>
        <div style="color:var(--text-muted); font-size:0.78rem;">Detailed user activity</div>
      </div>
    </div>
  </div>
</div>

<!-- Active sessions -->
<div class="glass-card p-4">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h5 class="fw-semibold mb-0" style="color:#0f172a;">
      <i class="fa-solid fa-users me-2" style="color:var(--indigo);"></i> Active Sessions
    </h5>
    <%
      let activeCount = 0;
      if (sessions && sessions.length > 0) {
        sessions.forEach(s => { if (s.userId) activeCount++; });
      }
    %>
    <span class="badge-neon"><%= activeCount %> active</span>
  </div>

  <% if (activeCount === 0) { %>
    <div class="text-center py-5">
      <i class="fa-solid fa-moon" style="font-size:2rem; color:var(--text-muted-custom); opacity:0.4;"></i>
      <p class="mt-3 mb-0" style="color:var(--text-muted); font-size:0.9rem;">No active user sessions right now.</p>
    </div>
  <% } else { %>
    <div class="d-flex flex-column gap-2">
      <% sessions.forEach(session => { %>
        <% if (session.userId) { %>
          <div class="d-flex align-items-center justify-content-between p-3" style="
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            transition: border-color 0.2s;
          ">
            <div class="d-flex align-items-center gap-3">
              <div style="
                width: 38px; height: 38px;
                border-radius: 10px;
                background: #eff6ff;
                border: 1px solid #bfdbfe;
                display: flex; align-items: center; justify-content: center;
                color: #3b82f6; font-size: 0.95rem;
                flex-shrink: 0;
              ">
                <i class="fa-solid fa-user"></i>
              </div>
              <div>
                <div style="color:#0f172a; font-size:0.875rem; font-weight:500; font-family:monospace;">
                  <%= session.userId %>
                </div>
                <div style="color:var(--text-muted); font-size:0.75rem;">
                  Session: <span style="font-family:monospace;"><%= session.sessionId.substring(0,20) %>...</span>
                </div>
              </div>
            </div>
            <a
              href="/admin/sessions/<%= session.sessionId %>/destroy"
              class="btn-danger-glass d-inline-flex align-items-center gap-1 text-decoration-none"
              onclick="return confirm('Terminate this session?')"
            >
              <i class="fa-solid fa-xmark"></i> Terminate
            </a>
          </div>
        <% } %>
      <% }) %>
    </div>
  <% } %>
</div>
